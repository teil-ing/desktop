{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "teil.ing",
  "version": "0.1.8",
  "identifier": "ing.teil.client.crossplatform",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "teil.ing",
        "width": 336,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://teil.ing https://*.teil.ing https:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://teil.ing"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["teiling"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxQTE2NTRFNkY3MDVEClJXUmRjRzlPWmFHeEFBVTBYOElPL0RVSFpxb1phdU9ENXRkRVJpZGl4QmRxTFhYME1EOExsa3VSCg==",
      "endpoints": [
        "https://github.com/teil-ing/desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
